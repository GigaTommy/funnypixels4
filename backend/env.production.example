# 生产环境配置模板
# 复制此文件为 .env.production 并填入实际的生产环境配置
# 注意：此文件不应提交到版本控制

# 环境标识
NODE_ENV=production

# 数据库配置（Render PostgreSQL）
DB_HOST=your-render-postgres-host
DB_PORT=5432
DB_USER=your-render-postgres-user
DB_PASSWORD=your-render-postgres-password
DB_NAME=your-render-postgres-database

# Redis配置（Upstash Redis）
UPSTASH_REDIS_REST_URL=https://novel-cub-21980.upstash.io
UPSTASH_REDIS_REST_TOKEN=AVXcAAIncDFkY2Y4MGFlZTFlYjc0ZTgyOWQ5ZjlkMWU0NTkzMzRhNXAxMjE5ODA

# JWT配置
JWT_SECRET=your-production-jwt-secret-key
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-key
JWT_EXPIRES_IN=7d

# 服务器配置
PORT=3001

# 优化配置
REDIS_BATCH_SIZE=100
REDIS_FLUSH_INTERVAL=300000
TILE_BATCH_TIMEOUT=50
TILE_CACHE_TTL=3600
LEADERBOARD_CACHE_TTL=600
STREAM_CACHE_TTL=86400

# 并发性能配置
MAX_CONCURRENT_CONNECTIONS=1000
WEBSOCKET_HEARTBEAT_INTERVAL=30000
TILE_SUBSCRIPTION_DEBOUNCE=100
VIEWPORT_UPDATE_THROTTLE=200

# 监控配置
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL=60000
REDIS_MEMORY_ALERT_THRESHOLD=50

# CORS配置
CORS_ORIGIN=https://funnypixels.pages.dev

# 支付配置（暂时禁用）
PAYMENT_MODE=disabled

# 前端URL
FRONTEND_URL=https://funnypixels.pages.dev
