/* Help & Feedback */
"help.segment.title" = "모드";
"help.segment.manual" = "도움말";
"help.segment.feedback" = "피드백";
"help.title" = "도움말 및 피드백";
"help.manual.welcome_title" = "👋 FunnyPixels에 오신 것을 환영합니다";
"help.manual.welcome_desc" = "FunnyPixels는 전 세계 플레이어가 함께 만드는 픽셀 지도입니다. GPS로 이동하며 픽셀 아트를 그리고, 동맹에 가입하여 영토를 점령하고, 전 세계 플레이어가 그린 픽셀 세계를 탐험하세요.";
"help.manual.getting_started_title" = "시작하기";
"help.manual.getting_started_desc" = "FunnyPixels를 실행하면 위치 권한을 요청합니다 — GPS 그리기에 필수입니다.\n\n내비게이션:\n- 지도: 글로벌 픽셀 캔버스 탐색, 주변 플레이어와 영토 확인\n- 피드: 소셜 피드, 그리기 기록, 데이터 대시보드\n- 동맹: 팀 가입 또는 생성, 함께 레벨업\n- 랭킹: 랭크 티어와 친구 랭킹이 포함된 리더보드\n- 마이: 프로필, 일일 작업, 업적, 설정\n\n오른쪽 하단의 둥근 버튼으로 GPS 그리기를 시작합니다. 길게 누르면 그리기 깃발을 전환합니다.\n\n빠른 통계: 지도의 플로팅 위젯으로 오늘의 픽셀, 세션, 일일 작업 진행률을 한눈에 확인하세요.";
"help.manual.gps_drawing_title" = "GPS 그리기";
"help.manual.gps_drawing_desc" = "GPS 그리기는 실제 이동 경로를 지도 위 픽셀 아트로 변환합니다.\n\n시작 방법:\n1. 그리고 싶은 지역으로 이동\n2. 원형 버튼을 탭하여 GPS 세션 시작\n3. 걸으면 경로가 픽셀로 변환\n4. 완료 후 정지 탭\n\n팁:\n- 시작 전 깃발 선택 (개인 색상, 아바타, 동맹 깃발)\n- 나침반이 이동 방향 표시\n- 픽셀 수, 거리, 속도 등 실시간 업데이트\n- 장시간 걷기에는 저전력 모드 사용 가능";
"help.manual.manual_drawing_title" = "수동 그리기";
"help.manual.manual_drawing_desc" = "지도를 탭하여 직접 픽셀을 배치합니다.\n\n그리기 모드:\n- 색상: 프리셋 색상에서 선택하거나 커스텀 색상을 고른 후 지도 탭\n- 이모지: 이모지를 선택하고 탭하여 배치\n- 패턴: 동맹 깃발이나 커스텀 패턴 사용\n\n지도 화면 하단의 그리기 모드 패널에서 모드를 전환합니다.";
"help.manual.map_explore_title" = "지도 및 탐색";
"help.manual.map_explore_desc" = "지도가 당신의 캔버스입니다.\n\n- 핀치로 확대/축소, 드래그로 전 세계 탐색\n- 픽셀을 탭하여 누가 언제 그렸는지 확인\n- 팀이 지배하는 지역에 동맹 깃발 표시\n- 탐색 패널로 주변 핫스팟 발견\n- 활성 대회 중 이벤트 존 하이라이트\n\n지도 기능:\n- 주변 플레이어: 실시간으로 주변에서 그리기 중인 플레이어 확인\n- 지역 정보 바: 지역 이름, 활성 플레이어 수, 픽셀 수, 지배 동맹 표시\n- 영토 제어: 동맹 영토가 색상 존으로 지도에 표시\n- 빠른 통계: 오늘의 픽셀, 세션, 일일 작업 진행률을 보여주는 플로팅 위젯";
"help.manual.history_title" = "피드 센터";
"help.manual.history_desc" = "피드 탭은 세 개의 섹션으로 구성된 콘텐츠 허브입니다:\n\n- 피드: 팔로우하는 플레이어의 그리기 활동, 업적 달성, 랭크 변동을 확인. 좋아요와 댓글 가능. \"날아가기\"를 탭하여 지도에서 그리기 위치를 방문.\n- 기록: 갤러리 또는 목록 형식으로 과거 그리기를 탐색. 세션을 탭하여 상세 정보, 통계, 지도 리플레이 확인. SNS 공유 또는 이미지 저장 가능.\n- 통계: 활동 캘린더(히트맵), 주간 트렌드, 도시 발자국을 포함한 개인 데이터 대시보드 — 그리기 여정을 추적.";
"help.manual.shop_title" = "상점 및 아이템";
"help.manual.shop_desc" = "포인트로 상점에서 아이템을 구매합니다.\n\n아이템 종류:\n- 폭탄: 대상 영역의 다른 플레이어 픽셀 제거\n- 부스트 카드: GPS 그리기 효율 향상\n- 광고: 커스텀 이미지를 지도에 게시 (심사 필요)\n- 커스텀 깃발: 동맹용 맞춤 깃발 업로드\n\n포인트 및 지갑:\n- 출석, 업적, 이벤트, 초대로 포인트 획득\n- WeChat Pay 또는 Alipay로 포인트 충전\n- 구매한 아이템은 '내 아이템'에서 확인";
"help.manual.alliance_title" = "동맹과 영토";
"help.manual.alliance_desc" = "다른 플레이어와 팀을 이루어 영토를 정복하세요.\n\n동맹 생성:\n- 동맹 탭에서 생성을 탭\n- 이름, 설명, 공개 설정, 깃발 패턴 설정\n\n동맹 깃발:\n- 색상: 단색 깃발\n- 이모지: 이모지 아이콘이 있는 깃발\n- 복합: 커스텀 패턴 이미지 업로드\n\n동맹 성장:\n- 동맹 레벨: 멤버 활동으로 XP를 획득하고 동맹을 레벨업하여 혜택 해제\n- 동맹 체크인: 멤버가 매일 체크인하여 동맹에 포인트 획득\n- 기여 랭킹: 가장 많은 픽셀을 기여한 멤버 확인\n\n관리:\n- 리더는 관리자 승격, 멤버 추방, 리더십 이전 가능\n- 초대 코드로 새 멤버 초대\n- 동맹 통계 확인: 총 픽셀, 영토, 세계 랭킹\n\n영토:\n- 지역을 지배하는 동맹이 해당 영토를 제어\n- 영토 존은 색상 오버레이로 지도에 표시\n- 영토를 탭하여 동맹 비율 상세 확인";
"help.manual.achievements_title" = "업적";
"help.manual.achievements_desc" = "활동을 완료하여 업적을 해제합니다.\n\n카테고리: 그리기, 소셜, 동맹, 상점, 활동, 특별\n\n희귀도: 일반, 고급, 희귀, 에픽, 전설\n\n작동 방식:\n- 플레이 중 자동으로 업적 해제\n- 업적 페이지(나 > 업적)에서 포인트 보상 수령\n- 업적 카드를 소셜 미디어에 공유\n- 획득한 배지는 프로필 명예의 벽에 표시";
"help.manual.events_title" = "이벤트 및 챌린지";
"help.manual.events_desc" = "기간 한정 이벤트에서 특별 보상을 획득합니다.\n\n이벤트 유형:\n- 리더보드 스프린트: 최다 픽셀을 그려 상위 랭크\n- 영토 전쟁: 지도 영역 지배권 경쟁\n- 협동: 모든 플레이어가 공동 목표 달성\n- 진영전: 동맹 대 동맹 대결\n\n참여 방법:\n- 이벤트 센터(나 > 이벤트 센터)에서 확인\n- 개인 또는 동맹으로 참가 신청\n- 지도에서 이벤트 존에 진입하여 기여\n- 이벤트 종료 시 보상 배분";
"help.manual.drift_bottle_title" = "표류병";
"help.manual.drift_bottle_desc" = "표류병에 메시지를 넣어 전 세계 낯선 사람에게 보내세요.\n\n표류병 획득:\n- 픽셀을 그려 표류병 획득 (화면에 진행 상황 표시)\n\n만들기:\n- 그리기 세션 후 짧은 메시지(최대 50자)를 작성하고 던지기\n\n발견:\n- 그리기 중 표류병과 조우\n- 열어서 메시지를 읽고, 자신의 메시지를 남기거나 계속 떠돌게 놓아주기\n\n여정 카드:\n- 5명이 표류병을 열면 침몰하고 모든 참여자가 여정 카드를 수령\n- 나 > 여정 컬렉션에서 수집";
"help.manual.leaderboard_title" = "리더보드";
"help.manual.leaderboard_desc" = "다른 플레이어와의 랭킹을 확인하세요.\n\n기간: 일간, 주간, 월간, 전체\n\n랭킹 유형:\n- 개인: 개인 픽셀 수\n- 동맹: 동맹 총 픽셀과 영토\n- 도시: 세계에서 가장 활발한 도시\n- 친구: 팔로우하는 플레이어 랭킹\n\n기능:\n- 랭크 티어: 픽셀 수에 따라 랭크 배지 획득 (브론즈부터 레전드)\n- 개인 랭크 카드: 상단에 랭크, 티어 배지, 통계 표시\n- Top 3 포디움: 상위 3명을 특별 포디움으로 소개\n- 랭크 변동: 애니메이션 인디케이터로 랭크 변화 표시";
"help.manual.daily_tasks_title" = "일일 작업";
"help.manual.daily_tasks_desc" = "일일 작업을 완료하여 보너스 보상을 획득하세요.\n\n방법:\n- 매일 작업 세트가 생성됩니다 (예: 픽셀 그리기, 체크인, 지도 탐색)\n- 프로그레스 바로 각 작업의 진행률 추적\n- 완료된 작업의 보상 수령\n- 모든 작업을 완료하면 특별 보너스 보상 해제\n\n일일 작업 접근:\n- 마이 > 일일 작업\n- 지도의 빠른 통계 위젯 (\"작업 보기\" 탭)\n\n작업 진행률은 플레이 중 자동 업데이트됩니다. 잊지 마세요 — 작업은 매일 리셋!";
"help.manual.social_title" = "소셜 & 팔로우";
"help.manual.social_desc" = "다른 플레이어와 연결하고 커뮤니티를 구축하세요.\n\n팔로우 시스템:\n- 프로필, 리더보드, 주변 플레이어 카드에서 플레이어를 팔로우\n- 프로필에서 팔로워와 팔로잉 목록 확인\n- 피드 탭에서 팔로우하는 플레이어의 활동 확인\n\n주변 플레이어:\n- 근처에서 그리기 중인 활성 플레이어가 지도에 표시\n- 플레이어 칩을 탭하여 정보 확인 및 팔로우\n- 지역 정보 바에서 지역 내 활성 플레이어 수 확인\n\n소셜 피드:\n- 그리기 작품과 업적에 좋아요와 댓글\n- 그리기 게시물의 \"날아가기\"를 탭하여 지도에서 위치 방문";
"help.manual.invite_title" = "친구 초대";
"help.manual.invite_desc" = "친구를 초대하고 보너스 포인트를 획득합니다.\n\n초대 방법:\n- 나 > 친구 초대로 이동\n- 고유 초대 코드를 복사 또는 공유\n- 친구가 가입 후 코드 입력\n\n보상:\n- 초대 성공마다 포인트 획득\n- 친구에게도 환영 보너스 포인트 제공\n- 초대 페이지에서 초대 통계 확인";
"help.manual.settings_title" = "설정 및 프로필";
"help.manual.settings_desc" = "경험을 맞춤 설정하세요.\n\n- 프로필 편집: 닉네임, 한줄 메시지, 아바타 변경\n- 표시: 글꼴 크기 조정 (컴팩트, 미디엄, 라지)\n- 언어: 앱 언어 전환 또는 시스템 설정 따르기\n- 사운드: 효과음 켜기/끄기\n- 개인정보: 다른 플레이어에게 닉네임, 동맹 정보, 깃발 숨기기\n- 일일 체크인: 매일 체크인하여 연속 보상, 주간 보상 사이클, 마일스톤 보너스 (30/90/180/365일) 획득\n- 일일 작업: 픽셀 그리기, 체크인, 지도 탐색 등의 일일 작업을 완료하여 보너스 보상 획득\n- 팔로우 & 팬: 프로필에서 팔로워와 팔로잉 목록 확인";
"help.feedback.section" = "피드백 작성";
"help.feedback.placeholder" = "제안이나 문제를 알려주세요...";
