<?xml version="1.0"?>
<gpx version="1.1" creator="FunnyPixels" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>北京城市游览路线</name>
    <desc>模拟在北京市区游览的GPS轨迹</desc>
    <author>FunnyPixels Team</author>
  </metadata>

  <!-- 起点：北京西站 -->
  <wpt lat="39.8943" lon="116.3219">
    <name>北京西站</name>
    <desc>起点：北京西站</desc>
    <time>2024-01-08T08:00:00Z</time>
  </wpt>

  <!-- 途经：军事博物馆 -->
  <wpt lat="39.9075" lon="116.3225">
    <name>军事博物馆</name>
    <desc>途经：军事博物馆站</desc>
    <time>2024-01-08T08:15:00Z</time>
  </wpt>

  <!-- 途经：天安门西 -->
  <wpt lat="39.9023" lon="116.3953">
