# 高德地图API配置
VITE_AMAP_API_KEY=your_api_key_here
VITE_AMAP_VERSION=2.0

# API配置
VITE_API_BASE_URL=https://your-backend-url.com
VITE_DOUYIN_API_BASE_URL=https://your-backend-url.com
VITE_WS_URL=ws://localhost:3001

# 应用配置
VITE_APP_NAME=FunnyPixels
VITE_APP_VERSION=1.0.0

# 登录配置
VITE_ENABLE_PHONE_LOGIN=true
VITE_ENABLE_AUTO_REGISTER=false

# 微信登录配置
# 请在微信开放平台申请并获取以下信息
VITE_WECHAT_APP_ID=YOUR_WECHAT_APP_ID
VITE_WECHAT_REDIRECT_URI=https://yourdomain.com/auth/wechat/callback

# 调试配置
VITE_DEBUG_MODE=false
VITE_ENABLE_MOCK_AUTH=false

# 地图引擎配置
VITE_USE_MAPLIBRE=true

# 地图默认位置配置
VITE_MAP_CENTER_LNG=113.324520
VITE_MAP_CENTER_LAT=23.109722
VITE_MAP_DEFAULT_ZOOM=12

# 地图样式配置 - 固定使用 OpenStreetMap 官方瓦片
# 标准地图样式，无CORS问题，性能稳定可靠

# 地图瓦片服务配置 - 用于像素渲染
VITE_TILE_SERVICE_URL=http://localhost:3001/api/tiles

# Emoji Atlas配置
VITE_EMOJI_ATLAS_CDN_URL=/assets/emoji