{
  "name": "funnypixels-backend",
  "version": "1.0.0",
  "description": "funnypixels 后端服务",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node src/server.js",
    "start:win": "set NODE_OPTIONS=--max-old-space-size=4096 && chcp 65001 && node src/server.js",
    "start:https": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ENABLE_HTTPS=true node src/server.js",
    "start:https:win": "set NODE_OPTIONS=--max-old-space-size=4096 && set ENABLE_HTTPS=true && chcp 65001 && node src/server.js",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nodemon src/server.js",
    "dev:win": "set NODE_OPTIONS=--max-old-space-size=4096 && chcp 65001 && nodemon src/server.js",
    "dev:https": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ENABLE_HTTPS=true nodemon src/server.js",
    "dev:https:win": "set NODE_OPTIONS=--max-old-space-size=4096 && set ENABLE_HTTPS=true && chcp 65001 && nodemon src/server.js",
    "build": "echo 'Backend build completed - Node.js project ready for deployment'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "seed:make": "knex seed:make",
    "migrate:make": "knex migrate:make",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "start:optimized": "bash scripts/start-optimized.sh",
    "start:optimized:win": "scripts\\start-optimized.bat",
    "test:optimization": "node scripts/testOptimization.js",
    "check:env": "node scripts/check-env-config.js",
    "debug:tiles": "node scripts/debug-tile-subscription.js",
    "tile-renderer:worker": "node src/workers/tileRenderWorker.js",
    "test:redis": "node scripts/test-redis-config.js",
    "test:concurrency": "node scripts/testConcurrencyOptimization.js",
    "pixels-history:start": "node scripts/start-pixels-history-system.js",
    "pixels-history:test": "node scripts/test-pixels-history-system.js",
    "pixels-history:queue": "node scripts/process-pixels-history-queue.js",
    "data:export": "node scripts/export-dev-data.js",
    "data:import": "node scripts/import-to-production.js",
    "data:migrate": "node scripts/migrate-dev-to-prod.js",
    "data:fix": "node scripts/fix-import-issues.js",
    "pixels-history:manage": "node scripts/manage-pixels-history.js",
    "pixels-history:archive": "node scripts/archive-pixels-history.js",
    "migrate:check": "node scripts/check-migrations.js",
    "migrate:check-prod": "node scripts/check-production-migrations.js",
    "setup-prod-env": "node scripts/setup-production-env.js",
    "ad:verify-palette": "node src/scripts/verify256ColorPalette.js",
    "ad:test-projection": "node scripts/tests/testAdPixelProjection.js",
    "ad:test-simple": "node scripts/tests/testSimpleAdProjection.js",
    "ad:monitor": "node src/scripts/monitorAdSystem.js",
    "l10n:check": "node ../scripts/localization/l10n_cli.js check",
    "l10n:generate": "node ../scripts/localization/l10n_cli.js generate",
    "l10n:push": "node ../scripts/localization/bulk_import_translations.js",
    "l10n:pseudo": "node ../scripts/localization/l10n_cli.js pseudo",
    "l10n:specifiers": "node ../scripts/localization/check_format_specifiers.js",
    "l10n:ci": "bash ../scripts/localization/ci_check_translations.sh",
    "l10n:tm:build": "node ../scripts/localization/translation_memory.js build",
    "l10n:stringsdict": "node ../scripts/localization/generate_stringsdict.js"
  },
  "keywords": [
    "funnypixels",
    "backend",
    "api",
    "express",
    "postgresql",
    "redis"
  ],
  "author": "FunnyPixels Team",
  "license": "MIT",
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.2.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.965.0",
    "@mapbox/vector-tile": "^2.0.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "@turf/turf": "^7.2.0",
    "@types/qrcode": "^1.5.5",
    "@upstash/redis": "^1.28.4",
    "apn": "^2.0.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "bullmq": "^4.15.0",
    "canvas": "^3.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "geojson": "^0.5.0",
    "geojson-vt": "^4.0.2",
    "h3-js": "^4.3.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.8.13",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.8.2",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "lru-cache": "^11.2.4",
    "marked": "^17.0.1",
    "maxmind": "^5.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "node-cron": "^4.2.1",
    "node-geocoder": "^4.4.1",
    "pbf": "^4.0.1",
    "pg": "^8.16.3",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "proj4": "^2.19.10",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^24.17.1",
    "qrcode": "^1.5.4",
    "redis": "^5.8.2",
    "reverse-geocoding": "^2.0.0",
    "sharp": "^0.34.3",
    "socket.io": "^4.7.4",
    "twemoji": "^14.0.2",
    "uuid": "^9.0.1",
    "vt-pbf": "^3.1.3",
    "winston": "^3.11.0"
  },
  "overrides": {
    "node-forge": "^1.3.3"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
