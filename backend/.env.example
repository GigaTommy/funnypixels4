# ===========================================
# 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=funnypixels_postgres
DB_USER=postgres
DB_PASSWORD=your_password

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# CDN配置
# ===========================================
# Provider选择: local（开发） | s3（AWS生产） | oss（阿里云生产）
CDN_PROVIDER=local

# CDN基础URL
CDN_BASE_URL=http://localhost:3001/uploads

# 本地存储路径（仅CDN_PROVIDER=local时生效）
CDN_LOCAL_PATH=./uploads/patterns

# AWS S3配置（CDN_PROVIDER=s3时使用）
# CDN_PROVIDER=s3
# CDN_BASE_URL=https://cdn.funnypixels.com
# CDN_BUCKET=funnypixels-patterns
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# 阿里云OSS配置（CDN_PROVIDER=oss时使用）
# CDN_PROVIDER=oss
# CDN_BASE_URL=https://cdn.funnypixels.com
# OSS_REGION=oss-cn-shanghai
# OSS_BUCKET=funnypixels-prod
# OSS_ACCESS_KEY_ID=your_oss_key
# OSS_ACCESS_KEY_SECRET=your_oss_secret

# ===========================================
# JWT配置
# ===========================================
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h

# ===========================================
# AI图像处理API配置
# ===========================================

# Adobe Creative Cloud API
ADOBE_API_KEY=your_adobe_api_key_here
ADOBE_CLIENT_ID=your_adobe_client_id_here
ADOBE_CLIENT_SECRET=your_adobe_client_secret_here

# Google Vision API
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# AWS Rekognition
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Azure Computer Vision
AZURE_VISION_API_KEY=your_azure_vision_api_key_here
AZURE_VISION_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# remove.bg API
REMOVEBG_API_KEY=your_removebg_api_key_here

# Clipdrop API
CLIPDROP_API_KEY=your_clipdrop_api_key_here

# Stable Diffusion
STABLE_DIFFUSION_API_URL=https://api.stability.ai/v1/generation/stable-diffusion-xl
STABLE_DIFFUSION_API_KEY=your_stable_diffusion_api_key_here

# Midjourney (通过Discord)
MIDJOURNEY_DISCORD_TOKEN=your_discord_bot_token_here
MIDJOURNEY_SERVER_ID=your_discord_server_id_here
MIDJOURNEY_CHANNEL_ID=your_discord_channel_id_here

# OpenAI DALL-E
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# 图像处理配置
# ===========================================
# 默认AI处理策略
AI_PROCESSING_STRATEGY=normal
AI_PROCESSING_BUDGET=normal
AI_PROCESSING_QUALITY=balanced

# 本地处理配置
ENABLE_LOCAL_PROCESSING=true
LOCAL_MODEL_PATH=./models/

# 图像限制
MAX_IMAGE_SIZE=10485760
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# ===========================================
# 文件存储配置
# ===========================================
UPLOAD_PATH=./uploads
CUSTOM_FLAGS_PATH=./uploads/custom_flags
MAX_FILE_SIZE=5242880

# ===========================================
# 应用配置
# ===========================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# 缓存配置
CACHE_TTL=1800
FLAG_CACHE_TTL=3600

# ===========================================
# 安全配置
# ===========================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS配置
CORS_ORIGIN=http://localhost:3000

# ===========================================
# 地理编码配置
# ===========================================
# Google Maps Geocoding API (for non-China regions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
USE_GOOGLE_GEOCODING=true