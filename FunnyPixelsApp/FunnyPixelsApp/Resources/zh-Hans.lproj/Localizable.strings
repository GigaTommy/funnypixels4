/* Help & Feedback */
"help.segment.title" = "模式";
"help.segment.manual" = "操作手册";
"help.segment.feedback" = "意见反馈";
"help.title" = "帮助与反馈";
"help.manual.welcome_title" = "👋 欢迎来到 FunnyPixels";
"help.manual.welcome_desc" = "FunnyPixels 是一个全球共创的像素地图。通过 GPS 在真实世界中移动来绘制像素画，加入联盟占领领地，探索全球玩家共同绘制的像素世界。";
"help.manual.getting_started_title" = "新手入门";
"help.manual.getting_started_desc" = "启动FunnyPixels后，系统会请求位置权限 — 这是GPS绘画的必要条件。\n\n导航：\n- 地图：浏览全球像素画布，查看附近玩家和领地\n- 动态：社交动态流、绘画记录和数据仪表盘\n- 联盟：加入或创建团队，一起升级\n- 排行：排行榜，含段位系统和好友排名\n- 我的：个人资料、每日任务、成就和设置\n\n右下角的圆形按钮可启动GPS绘画。长按可切换绘画旗帜。\n\n快速统计：地图上的浮窗可一目了然查看今日像素、会话和每日任务进度。";
"help.manual.gps_drawing_title" = "GPS 绘制";
"help.manual.gps_drawing_desc" = "GPS 绘制将你的真实移动轨迹转化为地图上的像素画。\n\n操作步骤：\n1. 移动到想要绘制的区域\n2. 点击圆形按钮开始 GPS 绘制\n3. 边走边画——你的轨迹会变成像素\n4. 完成后点击停止\n\n实用技巧：\n- 开始前可选择旗帜（个人颜色、头像或联盟旗帜）\n- 指南针显示你的前进方向\n- 像素数、距离、速度等数据实时更新\n- 长时间步行可开启低功耗模式";
"help.manual.manual_drawing_title" = "手动绘制";
"help.manual.manual_drawing_desc" = "在地图上点击即可直接放置像素。\n\n绘制模式：\n- 颜色模式：从预设颜色中选择或自定义颜色，点击地图放置\n- Emoji 模式：选择一个表情符号，点击放置\n- 图案模式：使用联盟旗帜或自定义图案\n\n通过地图底部的绘制模式面板切换不同模式。";
"help.manual.map_explore_title" = "地图与探索";
"help.manual.map_explore_desc" = "地图就是你的画布。\n\n- 双指缩放，拖动浏览全球\n- 点击任意像素查看谁在何时绘制\n- 联盟旗帜出现在团队主导的区域\n- 使用探索面板发现附近热点\n- 活动期间会高亮显示赛事区域\n\n地图功能：\n- 附近玩家：实时查看谁在附近绘画\n- 区域信息栏：显示区域名称、活跃玩家数、像素总数和控制联盟\n- 领地控制：联盟领地以彩色区域显示在地图上\n- 快速统计：浮窗显示今日像素、会话数和每日任务进度";
"help.manual.history_title" = "动态中心";
"help.manual.history_desc" = "动态Tab是你的内容中心，包含三个部分：\n\n- 动态：查看你关注的玩家的绘画活动、成就解锁和排名变化。可以点赞和评论。点击「飞往」可以在地图上查看绘画位置。\n- 记录：以画廊或列表格式查看你的所有绘画历史。点击任意会话查看详情、统计和地图回放。可分享到社交媒体或保存为图片。\n- 统计：个人数据仪表盘，含活动日历（热力图）、每周趋势和城市足迹 — 追踪你的绘画旅程。";
"help.manual.shop_title" = "商店与道具";
"help.manual.shop_desc" = "使用积分在商店中购买道具。\n\n道具类型：\n- 炸弹：清除目标区域内其他玩家的像素\n- 加成卡：提升 GPS 绘制效率\n- 广告位：将自定义图片投放到地图上（需审核）\n- 自定义旗帜：为联盟上传专属旗帜图案\n\n积分与钱包：\n- 通过签到、成就、活动和邀请好友获得积分\n- 支持微信支付和支付宝充值\n- 在「我的道具」中查看已购道具";
"help.manual.alliance_title" = "联盟与领地";
"help.manual.alliance_desc" = "与其他玩家组队征服领地。\n\n创建联盟：\n- 前往联盟Tab点击创建\n- 设置名称、描述、可见性和旗帜样式\n\n联盟旗帜：\n- 颜色：纯色旗帜\n- 表情：带表情图标的旗帜\n- 复杂：上传自定义图案\n\n联盟成长：\n- 联盟等级：通过成员活动获得经验值，升级联盟解锁福利\n- 联盟签到：成员每日签到为联盟赚取积分\n- 贡献排行：查看哪些成员贡献了最多像素\n\n管理：\n- 盟主可提拔管理员、踢出成员或转让领导权\n- 通过邀请码邀请新成员\n- 查看联盟统计：总像素、领地、世界排名\n\n领地：\n- 在某区域占据主导地位的联盟控制该领地\n- 领地区域以彩色覆盖层显示在地图上\n- 点击领地查看联盟占比详情";
"help.manual.achievements_title" = "成就系统";
"help.manual.achievements_desc" = "通过完成各种活动解锁成就。\n\n成就类别：像素绘制、社交、联盟、商店、活跃度、特殊\n\n稀有度：普通、优秀、稀有、史诗、传奇\n\n玩法说明：\n- 使用过程中自动解锁成就\n- 在成就页面（我的 > 成就）领取积分奖励\n- 分享成就卡片到社交媒体\n- 获得的勋章展示在个人主页的荣誉墙上";
"help.manual.events_title" = "赛事与挑战";
"help.manual.events_desc" = "参加限时赛事赢取特殊奖励。\n\n赛事类型：\n- 排行冲刺：绘制最多像素争夺排名\n- 领地争夺：争夺地图区域控制权\n- 全服共建：所有玩家共同完成目标\n- 阵营大战：联盟对联盟的对决\n\n如何参与：\n- 在赛事中心查看（我的 > 赛事中心）\n- 以个人或联盟身份报名\n- 在地图上进入赛事区域贡献像素\n- 赛事结束后自动发放奖励";
"help.manual.drift_bottle_title" = "漂流瓶";
"help.manual.drift_bottle_desc" = "在漂流瓶中给陌生人留言，让它漂向世界各地。\n\n获得瓶子：\n- 绘制像素即可累积漂流瓶（屏幕上显示进度）\n\n创建瓶子：\n- 绘制结束后，可以写一段短留言（最多50字）并扔出\n\n拾取瓶子：\n- 绘制过程中可能遇到漂流瓶\n- 打开阅读留言，写下你的留言或直接放走\n\n旅途卡片：\n- 当5人打开瓶子后，瓶子沉没，所有参与者获得旅途卡片\n- 在「我的 > 旅途集」中收藏";
"help.manual.leaderboard_title" = "排行榜";
"help.manual.leaderboard_desc" = "查看你与其他玩家的排名对比。\n\n时间范围：每日、每周、每月、总榜\n\n排行类型：\n- 个人：个人像素数排名\n- 联盟：联盟总像素和领地排名\n- 城市：全球最活跃城市排名\n- 好友：你关注的玩家排名\n\n功能亮点：\n- 段位系统：根据像素数获得段位徽章（青铜到传奇）\n- 个人排名卡：顶部展示你的排名、段位和统计数据\n- Top 3 展台：前三名玩家以特别展台展示\n- 排名变动：动画指示器显示排名变化";
"help.manual.daily_tasks_title" = "每日任务";
"help.manual.daily_tasks_desc" = "完成每日任务获得额外奖励。\n\n玩法说明：\n- 每天系统会生成一组任务（如：绘制像素、签到、探索地图）\n- 通过进度条追踪每个任务的完成进度\n- 完成任务后领取奖励\n- 完成所有任务可解锁特别奖励\n\n访问每日任务：\n- 我的 > 每日任务\n- 地图上的快速统计浮窗（点击「查看任务」）\n\n任务进度会在你游玩时自动更新。别忘了 — 任务每天重置！";
"help.manual.social_title" = "社交与关注";
"help.manual.social_desc" = "与其他玩家建立联系，构建你的社区。\n\n关注系统：\n- 从玩家主页、排行榜或附近玩家卡片关注其他玩家\n- 在个人主页查看粉丝和关注列表\n- 在动态Tab查看你关注的玩家的活动\n\n附近玩家：\n- 在你附近绘画的活跃玩家会显示在地图上\n- 点击玩家标签查看信息并关注\n- 区域信息栏显示你所在区域的活跃玩家数\n\n社交动态：\n- 点赞和评论绘画作品和成就\n- 点击绘画帖子上的「飞往」可在地图上查看位置";
"help.manual.invite_title" = "邀请好友";
"help.manual.invite_desc" = "邀请好友，双方均可获得积分奖励。\n\n如何邀请：\n- 进入「我的 > 邀请好友」\n- 复制或分享你的专属邀请码\n- 好友注册后输入邀请码即可\n\n奖励说明：\n- 每成功邀请一人，你将获得积分\n- 你的好友同时获得迎新积分\n- 在邀请页面查看邀请统计";
"help.manual.settings_title" = "设置与个人资料";
"help.manual.settings_desc" = "自定义你的体验。\n\n- 编辑资料：修改昵称、个性签名和头像\n- 显示：调整字体大小（紧凑、中等、大号）\n- 语言：切换应用语言或跟随系统设置\n- 声音：开关音效\n- 隐私：对其他人隐藏昵称、联盟信息或旗帜\n- 每日签到：每天签到获得连续奖励、每周奖励周期和里程碑奖励（30/90/180/365天）\n- 每日任务：完成绘画像素、签到、探索地图等每日任务获得额外奖励\n- 关注与粉丝：在个人主页查看粉丝和关注列表";
