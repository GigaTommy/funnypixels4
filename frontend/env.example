# 高德地图配置
# 请复制此文件为 .env 并填入您的实际配置

# 高德地图API密钥（必需）
# 获取地址：https://console.amap.com/
VITE_AMAP_API_KEY="your_amap_api_key"

# 高德地图API版本（建议使用2.0）
VITE_AMAP_API_VERSION="2.0"

# 后端API配置
VITE_API_BASE_URL="your_api_base_url"
VITE_WS_URL="your_websocket_url"

# 重要：请确保API密钥已在高德开放平台绑定以下域名：
# - localhost
# - 127.0.0.1
# - localhost:5173
# - localhost:5174
# - 您的生产域名
