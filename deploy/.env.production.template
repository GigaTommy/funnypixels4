# ===========================================
# FunnyPixels Production Environment Variables
# Copy to project root: cp deploy/.env.production.template .env.production
# Then fill in actual values
# ===========================================

# ===========================================
# Core
# ===========================================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
LOG_TO_FILE=true

# ===========================================
# Cluster Mode (Node.js cluster)
# ===========================================
CLUSTER_MODE=true
CLUSTER_WORKERS=2

# ===========================================
# Database (Docker Compose internal network)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=funnypixels_postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_SSL=false
DB_POOL_MIN=5
DB_POOL_MAX=30

# ===========================================
# Redis (Docker Compose internal network)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
REDIS_DB=0

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING
BCRYPT_ROUNDS=12

# ===========================================
# URL Configuration
# ===========================================
BASE_URL=https://api.funnypixelsapp.com
FRONTEND_URL=https://funnypixelsapp.com
WS_URL=wss://api.funnypixelsapp.com
CORS_ORIGIN=https://funnypixelsapp.com,https://admin.funnypixelsapp.com

# ===========================================
# CDN / File Storage
# Initial: local storage + Cloudflare proxy caching
# Later: switch to CDN_PROVIDER=s3 or CDN_PROVIDER=r2
# ===========================================
CDN_PROVIDER=local
CDN_BASE_URL=https://api.funnypixelsapp.com

# Local file upload paths (container paths)
UPLOAD_PATH=./uploads
CUSTOM_FLAGS_PATH=./uploads/custom_flags
MAX_FILE_SIZE=5242880

# Cloudflare R2 (uncomment when ready)
# CDN_PROVIDER=r2
# R2_ACCOUNT_ID=your_r2_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_ACCESS_KEY_SECRET=your_r2_secret
# R2_BUCKET=funnypixels-prod
# R2_PUBLIC_URL=https://cdn.funnypixelsapp.com

# AWS S3 (alternative)
# CDN_PROVIDER=s3
# S3_REGION=us-west-2
# S3_BUCKET=funnypixels-prod
# S3_ACCESS_KEY_ID=your_s3_access_key
# S3_ACCESS_KEY_SECRET=your_s3_secret

# ===========================================
# Apple IAP
# ===========================================
# APPLE_SHARED_SECRET=your_apple_shared_secret

# ===========================================
# Map API
# ===========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
USE_GOOGLE_GEOCODING=true
USE_POSTGIS_GEOCODING=true
USE_REGIONS_GEOCODING=true

# ===========================================
# Push Notifications (APNs)
# ===========================================
# APN_KEY_ID=your_apn_key_id
# APN_TEAM_ID=your_apn_team_id
# APN_BUNDLE_ID=com.yourcompany.funnypixels

# ===========================================
# AI Image Processing (optional)
# ===========================================
# OPENAI_API_KEY=your_openai_api_key
# GOOGLE_VISION_API_KEY=your_google_vision_api_key
# REMOVEBG_API_KEY=your_removebg_api_key

# ===========================================
# Image Processing
# ===========================================
AI_PROCESSING_STRATEGY=normal
AI_PROCESSING_BUDGET=normal
AI_PROCESSING_QUALITY=balanced
ENABLE_LOCAL_PROCESSING=false
MAX_IMAGE_SIZE=10485760
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp
SUPPORT_AVIF=false

# ===========================================
# Security
# ===========================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
ENABLE_HTTPS=false

# ===========================================
# Cache
# ===========================================
CACHE_TTL=1800
FLAG_CACHE_TTL=3600
TILE_CACHE_TTL=300

# ===========================================
# Batch Pixel Processing
# ===========================================
BATCH_SIZE=100
BATCH_FLUSH_INTERVAL=1000
MAX_BATCH_SIZE=500

# ===========================================
# Monitoring (Grafana)
# ===========================================
GRAFANA_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ===========================================
# Payment Mode
# ===========================================
# PAYMENT_MODE=production

# ===========================================
# Local Validation (must be false in production)
# ===========================================
LOCAL_VALIDATION=false
