# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=funnypixels
DB_USER=postgres
DB_PASSWORD=your_password

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRES_IN=7d

# 高德地图API配置
AMAP_API_KEY=your_amap_api_key

# 文件上传配置
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# 像素绘制优化配置
REDIS_BATCH_SIZE=100
REDIS_FLUSH_INTERVAL=300000
TILE_BATCH_TIMEOUT=50
TILE_CACHE_TTL=3600
LEADERBOARD_CACHE_TTL=600
STREAM_CACHE_TTL=86400

# 并发性能配置
MAX_CONCURRENT_CONNECTIONS=1000
WEBSOCKET_HEARTBEAT_INTERVAL=30000
TILE_SUBSCRIPTION_DEBOUNCE=100
VIEWPORT_UPDATE_THROTTLE=200

# 监控配置
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL=60000
REDIS_MEMORY_ALERT_THRESHOLD=50
