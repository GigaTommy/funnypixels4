/* Help & Feedback */
"help.segment.title" = "モード";
"help.segment.manual" = "ガイド";
"help.segment.feedback" = "フィードバック";
"help.title" = "ヘルプとフィードバック";
"help.manual.welcome_title" = "👋 FunnyPixels へようこそ";
"help.manual.welcome_desc" = "FunnyPixels は世界中のプレイヤーが共同で作るピクセルマップです。GPS で移動しながらピクセルアートを描き、アライアンスに参加して領土を征服し、世界中のプレイヤーが描いたピクセルワールドを探索しましょう。";
"help.manual.getting_started_title" = "はじめに";
"help.manual.getting_started_desc" = "FunnyPixelsを起動すると、位置情報の許可を求められます — GPS描画に必要です。\n\nナビゲーション：\n- マップ：グローバルピクセルキャンバスを閲覧、近くのプレイヤーやテリトリーを確認\n- フィード：ソーシャルフィード、描画記録、データダッシュボード\n- アライアンス：チームに参加または作成、一緒にレベルアップ\n- ランク：ランクティアとフレンドランキング付きリーダーボード\n- マイ：プロフィール、デイリータスク、実績、設定\n\n右下の丸いボタンでGPS描画を開始。長押しで描画フラグを切り替え。\n\nクイック統計：マップ上のフローティングウィジェットで今日のピクセル、セッション、デイリータスクの進捗を一目で確認。";
"help.manual.gps_drawing_title" = "GPS 描画";
"help.manual.gps_drawing_desc" = "GPS 描画は実際の移動をマップ上のピクセルアートに変換します。\n\n始め方：\n1. 描きたいエリアに移動\n2. 丸いボタンをタップして GPS セッション開始\n3. 歩くと軌跡がピクセルに\n4. 完了したらストップをタップ\n\nヒント：\n- 開始前にフラグを選択（パーソナルカラー、アバター、アライアンスフラグ）\n- コンパスが進行方向を表示\n- ピクセル数、距離、速度などリアルタイムで更新\n- 長時間の散歩には省電力モードが利用可能";
"help.manual.manual_drawing_title" = "手動描画";
"help.manual.manual_drawing_desc" = "マップをタップしてピクセルを直接配置します。\n\n描画モード：\n- カラー：プリセットカラーから選択またはカスタムカラーを選び、マップをタップ\n- 絵文字：絵文字を選択してタップして配置\n- パターン：アライアンスフラグやカスタムパターンを使用\n\nマップ画面下部の描画モードパネルでモードを切り替え。";
"help.manual.map_explore_title" = "マップと探索";
"help.manual.map_explore_desc" = "マップはあなたのキャンバスです。\n\n- ピンチでズーム、ドラッグで世界を探索\n- ピクセルをタップして誰がいつ描いたか確認\n- チームが支配するエリアにアライアンスフラグが表示\n- 探索パネルで近くのホットスポットを発見\n- アクティブな大会中はイベントゾーンがハイライト表示\n\nマップ機能：\n- 近くのプレイヤー：リアルタイムで近くで描画中のプレイヤーを確認\n- 地域情報バー：エリア名、アクティブプレイヤー数、ピクセル数、支配アライアンスを表示\n- テリトリー制御：アライアンスのテリトリーがカラーゾーンでマップに表示\n- クイック統計：今日のピクセル、セッション、デイリータスク進捗を表示するフローティングウィジェット";
"help.manual.history_title" = "フィードセンター";
"help.manual.history_desc" = "フィードタブは3つのセクションからなるコンテンツハブです：\n\n- フィード：フォローしているプレイヤーの描画活動、実績解除、ランク変動を確認。いいねやコメントが可能。「飛ぶ」をタップしてマップ上の描画場所を訪問。\n- 記録：ギャラリーまたはリスト形式で過去の描画を閲覧。セッションをタップして詳細、統計、マップリプレイを確認。SNSへのシェアや画像保存も可能。\n- 統計：アクティビティカレンダー（ヒートマップ）、週次トレンド、都市フットプリントを含む個人データダッシュボード — 描画の旅を追跡。";
"help.manual.shop_title" = "ショップとアイテム";
"help.manual.shop_desc" = "ポイントでアイテムを購入。\n\nアイテム種類：\n- ボム：ターゲットエリアの他プレイヤーのピクセルを消去\n- ブーストカード：GPS 描画効率を向上\n- 広告：カスタム画像をマップに掲載（審査あり）\n- カスタムフラグ：アライアンス用のオリジナルフラグをアップロード\n\nポイントとウォレット：\n- チェックイン、実績、イベント、招待でポイント獲得\n- WeChat Pay や Alipay でポイントチャージ\n- 購入品は「マイアイテム」で確認";
"help.manual.alliance_title" = "アライアンスとテリトリー";
"help.manual.alliance_desc" = "他のプレイヤーとチームを組んでテリトリーを征服。\n\nアライアンス作成：\n- アライアンスタブで作成をタップ\n- 名前、説明、公開設定、フラグパターンを設定\n\nアライアンスフラグ：\n- カラー：単色フラグ\n- 絵文字：絵文字アイコン付きフラグ\n- 複合：カスタムパターン画像をアップロード\n\nアライアンス成長：\n- アライアンスレベル：メンバーの活動でXPを獲得し、アライアンスをレベルアップして特典を解除\n- アライアンスチェックイン：メンバーが毎日チェックインしてアライアンスにポイントを獲得\n- 貢献ランキング：最も多くピクセルを貢献したメンバーを確認\n\n管理：\n- リーダーは管理者の昇格、メンバーのキック、リーダーシップの移譲が可能\n- 招待コードで新メンバーを招待\n- アライアンス統計を確認：総ピクセル、テリトリー、世界ランキング\n\nテリトリー：\n- エリアを支配するアライアンスがそのテリトリーを制御\n- テリトリーゾーンはカラーオーバーレイでマップに表示\n- テリトリーをタップしてアライアンスの内訳を確認";
"help.manual.achievements_title" = "実績";
"help.manual.achievements_desc" = "活動を完了して実績を解除。\n\nカテゴリ：描画、ソーシャル、アライアンス、ショップ、活動、特別\n\nレアリティ：コモン、アンコモン、レア、エピック、レジェンダリー\n\n仕組み：\n- プレイ中に自動で実績が解除\n- 実績ページ（マイ > 実績）でポイント報酬を獲得\n- 実績カードをソーシャルメディアでシェア\n- 獲得バッジはプロフィールの栄誉の壁に表示";
"help.manual.events_title" = "イベントとチャレンジ";
"help.manual.events_desc" = "期間限定イベントで特別報酬を獲得。\n\nイベント種類：\n- ランキングスプリント：最多ピクセルを描いてランク上位へ\n- テリトリーウォー：マップエリアの支配権を争う\n- 共同作戦：全プレイヤーで共通目標を達成\n- 陣営戦：アライアンス対アライアンスの対決\n\n参加方法：\n- イベントセンター（マイ > イベントセンター）で確認\n- 個人またはアライアンスとして参加登録\n- マップ上のイベントゾーンに入ってピクセルを貢献\n- イベント終了時に報酬が配布";
"help.manual.drift_bottle_title" = "漂流ボトル";
"help.manual.drift_bottle_desc" = "ボトルにメッセージを入れて世界中の見知らぬ人に届けよう。\n\nボトルの獲得：\n- ピクセルを描いて漂流ボトルを獲得（画面に進捗表示）\n\n作成：\n- 描画セッション後、短いメッセージ（最大50文字）を書いて投げる\n\n発見：\n- 描画中にボトルに遭遇\n- 開いてメッセージを読み、自分のメッセージを残すか、放流して旅を続けさせる\n\n旅カード：\n- 5人がボトルを開くと沈没し、全参加者が旅カードを受け取る\n- マイ > 旅コレクションで収集";
"help.manual.leaderboard_title" = "ランキング";
"help.manual.leaderboard_desc" = "他のプレイヤーとのランキングを確認。\n\n期間：デイリー、ウィークリー、マンスリー、全期間\n\nランキングタイプ：\n- 個人：個人ピクセル数\n- アライアンス：アライアンス総ピクセルとテリトリー\n- 都市：世界で最もアクティブな都市\n- フレンド：フォローしているプレイヤーのランキング\n\n機能：\n- ランクティア：ピクセル数に基づいてランクバッジを獲得（ブロンズからレジェンド）\n- 個人ランクカード：トップにランク、ティアバッジ、統計を表示\n- Top3表彰台：上位3名のプレイヤーを特別な表彰台で紹介\n- ランク変動：アニメーション付きインジケーターでランクの変化を表示";
"help.manual.daily_tasks_title" = "デイリータスク";
"help.manual.daily_tasks_desc" = "デイリータスクを完了してボーナス報酬を獲得。\n\n遊び方：\n- 毎日タスクのセットが生成されます（例：ピクセルを描く、チェックイン、マップを探索）\n- プログレスバーで各タスクの進捗を追跡\n- 完了したタスクの報酬を受け取る\n- すべてのタスクを完了すると特別ボーナス報酬を解除\n\nデイリータスクへのアクセス：\n- マイ > デイリータスク\n- マップのクイック統計ウィジェット（「タスクを見る」をタップ）\n\nタスクの進捗はプレイ中に自動更新されます。お忘れなく — タスクは毎日リセット！";
"help.manual.social_title" = "ソーシャル＆フォロー";
"help.manual.social_desc" = "他のプレイヤーとつながり、コミュニティを構築。\n\nフォローシステム：\n- プロフィール、リーダーボード、近くのプレイヤーカードからプレイヤーをフォロー\n- プロフィールからフォロワーとフォロー中のリストを確認\n- フィードタブでフォローしているプレイヤーの活動を確認\n\n近くのプレイヤー：\n- 近くで描画中のアクティブなプレイヤーがマップに表示\n- プレイヤーチップをタップして情報を確認しフォロー\n- 地域情報バーでエリア内のアクティブプレイヤー数を確認\n\nソーシャルフィード：\n- 描画作品や実績にいいねやコメント\n- 描画投稿の「飛ぶ」をタップしてマップ上の場所を訪問";
"help.manual.invite_title" = "友達を招待";
"help.manual.invite_desc" = "友達を招待してボーナスポイントを獲得。\n\n招待方法：\n- マイ > 友達を招待へ\n- 固有の招待コードをコピーまたはシェア\n- 友達が登録後にコードを入力\n\n報酬：\n- 招待成功ごとにポイント獲得\n- 友達にもウェルカムボーナスポイント\n- 招待ページで招待統計を確認";
"help.manual.settings_title" = "設定とプロフィール";
