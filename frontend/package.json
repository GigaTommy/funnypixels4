{
  "name": "funnypixels-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:douyin": "vite --config vite.config.douyin.js --port 5174",
    "build": "tsc && vite build",
    "build:douyin": "tsc && vite build --config vite.config.douyin.js",
    "build:douyin:preact": "tsc && vite build --config vite.config.douyin.preact.js",
    "preview": "vite preview",
    "preview:douyin": "vite preview --config vite.config.douyin.js --port 4174",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze:douyin": "vite build --config vite.config.douyin.js --mode analyze"
  },
  "dependencies": {
    "@amap/amap-jsapi-types": "^0.0.15",
    "@mapbox/sphericalmercator": "^2.0.2",
    "@preact/preset-vite": "^2.10.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/maplibre-gl": "^1.13.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.7.0",
    "@zxing/library": "^0.21.3",
    "axios": "^1.6.2",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "coordtransform": "^2.1.2",
    "date-fns": "^2.30.0",
    "flag-icons": "^7.5.0",
    "framer-motion": "^10.18.0",
    "html5-qrcode": "^2.3.8",
    "lodash": "^4.17.21",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.294.0",
    "maplibre-gl": "^5.15.0",
    "preact": "^10.27.2",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-router-dom": "^6.20.1",
    "remixicon": "^4.7.0",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^3.3.1",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "vite": "^7.3.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^24.3.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "autoprefixer": "^10.4.16",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "baseline-browser-mapping": "^2.9.18",
    "core-js": "^3.47.0",
    "cssnano": "^6.0.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "terser": "^5.44.0",
    "ts-jest": "^29.1.1"
  },
  "keywords": [
    "funnypixels",
    "frontend",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "douyin",
    "minigame"
  ],
  "author": "FunnyPixels Team",
  "license": "MIT"
}
