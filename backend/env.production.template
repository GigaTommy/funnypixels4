# 生产环境配置模板 - 用于连接Render数据库
# 复制此文件为 .env.production 并填入实际值

NODE_ENV=production
LOCAL_VALIDATION=false

# Render数据库配置 - 请替换为你的实际值
DB_HOST=your-render-db-host
DB_PORT=5432
DB_USER=your-render-db-user
DB_PASSWORD=your-render-db-password
DB_NAME=your-render-db-name

# Upstash Redis配置 - 请替换为你的实际值
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# JWT配置
JWT_SECRET=c486375261c9f7591443fe1959174a0e
JWT_REFRESH_SECRET=c486375261c9f7591443fe1959174a0e_refresh
