# ==========================================
# 📋 FunnyPixels 配置模板
# ==========================================
# 复制此文件为 .env 并修改配置: cp .env.example .env
# 修改配置后运行同步命令: npm run sync-config

# ==========================================
# 🌍 环境配置 (Environment Configuration)
# ==========================================
# 修改此处将自动同步到所有客户端配置文件

# 开发环境 (Development) - 请根据您的局域网 IP 修改
DEV_SERVER_IP=192.168.0.3
DEV_SERVER_PORT=3001
DEV_FRONTEND_PORT=3000
DEV_API_BASE_URL=http://192.168.0.3:3001
DEV_WEB_BASE_URL=http://192.168.0.3:3000
DEV_WS_URL=ws://192.168.0.3:3001

# 生产环境 (Production)
PROD_API_BASE_URL=https://api.funnypixelsapp.com
PROD_WEB_BASE_URL=https://funnypixelsapp.com
PROD_WS_URL=wss://api.funnypixelsapp.com

# ==========================================
# 🗄️ 数据库配置
# ==========================================
HOST=0.0.0.0
DB_HOST=localhost
DB_PORT=5432
DB_NAME=funnypixels_postgres
DB_USER=postgres
DB_PASSWORD=password

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 服务器配置
PORT=3001
HTTPS_PORT=3443
ENABLE_HTTPS=true
NODE_ENV=development

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRES_IN=7d

# 高德地图API配置
AMAP_API_KEY=your_amap_api_key

# 文件上传配置
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# 像素绘制优化配置
REDIS_BATCH_SIZE=100
REDIS_FLUSH_INTERVAL=300000
TILE_BATCH_TIMEOUT=50
TILE_CACHE_TTL=3600
LEADERBOARD_CACHE_TTL=600
STREAM_CACHE_TTL=86400

# 并发性能配置
MAX_CONCURRENT_CONNECTIONS=1000
WEBSOCKET_HEARTBEAT_INTERVAL=30000
TILE_SUBSCRIPTION_DEBOUNCE=100
VIEWPORT_UPDATE_THROTTLE=200

# 监控配置
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL=60000
REDIS_MEMORY_ALERT_THRESHOLD=50

# 本地验证模式
LOCAL_VALIDATION=true

# 阿里云短信服务配置
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=FunnyPixels
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxx

# 登录配置
ENABLE_PHONE_LOGIN=true
ENABLE_AUTO_REGISTER_IN_DEV=true
SMS_CODE_EXPIRE_TIME=300
SMS_RATE_LIMIT_TIME=60

# 🆕 Emoji Atlas 配置
# 本地开发环境（使用本地文件）
VITE_EMOJI_ATLAS_CDN_URL=/assets/emoji

# 生产环境（使用 CDN）
# VITE_EMOJI_ATLAS_CDN_URL=https://cdn.yourdomain.com/emoji

# 🆕 MapLibre GL 配置
# 是否启用MapLibre GL (true=MapLibre GL, false=高德地图)
VITE_USE_MAPLIBRE=true

# 🗺️ 地图瓦片服务配置
# 使用OpenStreetMap (完全免费的开放地图瓦片)
# 无需配置API key，直接可用
