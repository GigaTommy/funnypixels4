{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FunnyPixels Environment Configuration",
  "description": "环境配置定义，供所有前端使用",
  "version": "1.0.0",
  "environments": {
    "development": {
      "name": "Development",
      "displayName": "开发环境",
      "apiBaseURL": "http://localhost:3001/api",
      "wsURL": "ws://localhost:3001",
      "enableDebug": true,
      "enableVerboseLogging": true,
      "requestTimeout": 60,
      "description": "本地开发环境"
    },
    "staging": {
      "name": "Staging",
      "displayName": "测试环境",
      "apiBaseURL": "https://staging-api.funnypixels.com/api",
      "wsURL": "wss://staging-api.funnypixels.com",
      "enableDebug": true,
      "enableVerboseLogging": false,
      "requestTimeout": 30,
      "description": "测试服务器环境"
    },
    "production": {
      "name": "Production",
      "displayName": "生产环境",
      "apiBaseURL": "https://api.funnypixels.com/api",
      "wsURL": "wss://api.funnypixels.com",
      "enableDebug": false,
      "enableVerboseLogging": false,
      "requestTimeout": 30,
      "description": "生产服务器环境"
    }
  }
}


